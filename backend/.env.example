# ── Recall.ai ────────────────────────────────────────────────────────────────
RECALL_API_KEY=
RECALL_API_BASE_URL=https://us-west-2.recall.ai/api/v1
RECALL_WEBHOOK_SECRET=
# Set true for local dev only — never in production.
RECALL_SKIP_WEBHOOK_VERIFY=false

# ── App URLs ──────────────────────────────────────────────────────────────────
# Set to your public tunnel or deployed URL. start-local.sh patches these automatically.
BACKEND_URL=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
ADMIN_API_KEY=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_VAD_THRESHOLD=0.82
OPENAI_REALTIME_VAD_SILENCE_MS=900
OPENAI_REALTIME_VAD_PREFIX_PADDING_MS=450
OPENAI_REALTIME_INTERRUPT_RESPONSE=false
VOICE_AGENT_MODE=realtime

# ── Anthropic (Claude Vision indexing) ───────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-1-20250805
# Model used for per-slide Claude Vision extraction (defaults to ANTHROPIC_MODEL if blank)
INDEXER_LLM_MODEL=
# Max parallel Claude Vision calls during indexing
INDEXER_VISION_CONCURRENCY=3

# ── Azure AI Search ───────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX_NAME=overtone

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_BLOB_ACCOUNT_URL=
AZURE_BLOB_ACCOUNT_KEY=
AZURE_BLOB_CONTAINER_NAME=presentations
AZURE_BLOB_UPLOAD_SAS_TTL_MINUTES=30

# ── ElevenLabs TTS ────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Storage & Sessions ────────────────────────────────────────────────────────
# local = SQLite + filesystem. dynamodb = DynamoDB metadata + Azure Blob files.
STORAGE_BACKEND=local
AGENTS_DB_PATH=./data/agents.db
MAX_UPLOAD_BYTES=52428800
SESSION_TTL_SECONDS=86400
SESSION_CLEANUP_INTERVAL_SECONDS=60
WEBHOOK_DEDUPE_TTL_SECONDS=3600

# ── Database (set for production / Cloud Run; omit for local SQLite) ─────────
# Example: postgresql+psycopg2://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=

# ── Optional: Redis (durable transcript queue across restarts) ────────────────
REDIS_URL=
REDIS_KEY_PREFIX=voicenav

# ── Optional: AWS DynamoDB (only when STORAGE_BACKEND=dynamodb) ──────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DYNAMODB_PRESENTATIONS_TABLE=voicenav-presentations-meta
